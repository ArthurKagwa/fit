# Postgres connection string (Neon / Vercel Postgres pooled URL in production).
# Holds structured fitness data (runs, workouts, meals, goals, plans, ...).
DATABASE_URL="postgresql://user:password@localhost:5432/fit"

# MongoDB — stores chat conversations + messages (see src/lib/chat-store.ts)
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB="fit"

# Secret for Auth.js JWT sessions — generate with: openssl rand -base64 32
AUTH_SECRET=""

# OpenRouter API key — optional; without it the app runs with AI features disabled
OPENROUTER_API_KEY=""

# Optional per-tier model override (OpenRouter id). Leave blank to use the
# built-in free-model fleets in src/lib/ai/client.ts, which auto-fall-back to
# the next free model when one is rate-limited (429).
MODEL_CHAT=""
MODEL_EXTRACT=""
MODEL_LIGHT=""

# Vercel Blob token — optional in dev (falls back to local .uploads/ storage)
BLOB_READ_WRITE_TOKEN=""
